# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# Virtual environment — never commit this (it's huge and machine-specific)
venv/
.venv/
env/

# Environment variables — API keys, secrets, never commit
.env

# Data files — raw scraped data stays local, not in version control
data/raw/
data/processed/*.csv

# Jupyter notebook checkpoints
.ipynb_checkpoints/

# macOS
.DS_Store

# Editor
.vscode/
.idea/

# pytest cache
.pytest_cache/

# Brand cache - regenerated automatically
data/brands/

# Per-run CSVs I fill in manually, not source code
data/validation/

# Runtime logs
logs/
scripts/logs/

# Claude Code workspace files
.agents/

# Claude Code memory files
memory/
